# ─── Supabase / PostgreSQL ──────────────────────────────────
# En Supabase → Settings → Database → Connection string

# "Transaction" pooler (usado por la app en producción)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# "Session" mode o direct (usado solo por Prisma para migrations)
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# ─── Auth ────────────────────────────────────────────────────
# Generá uno con: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-in-production"
# URL pública de tu app (sin trailing slash)
NEXTAUTH_URL="https://tu-app.netlify.app"

# ─── Stripe (futuro — suscripciones DM) ─────────────────────
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
# STRIPE_MONTHLY_PRICE_ID="price_..."
# STRIPE_ANNUAL_PRICE_ID="price_..."
