# ─── Database ───────────────────────────────────────────────
# Local development (SQLite file — default, no changes needed)
DATABASE_URL="file:./dev.db"

# Turso cloud (production) — get these from https://turso.tech
# After: turso db create dungeonhub
#        turso db show dungeonhub          → TURSO_DATABASE_URL
#        turso db tokens create dungeonhub → TURSO_AUTH_TOKEN
TURSO_DATABASE_URL="libsql://your-db-name.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# ─── Auth ────────────────────────────────────────────────────
# Generate a secure random string: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-in-production"
# Your production domain (no trailing slash)
NEXTAUTH_URL="https://your-app.netlify.app"

# ─── Stripe (future — DM subscriptions) ─────────────────────
# STRIPE_SECRET_KEY="sk_live_..."
